@startuml
!theme plain
title YAS — Backoffice Architecture

skinparam backgroundColor #FAFAFA
skinparam fontSize 10

actor "Admin" as admin

rectangle "Backoffice UI\n(Next.js 14)" as bo_ui #FFE4B5

rectangle "Backoffice BFF\n(OAuth2 TokenRelay)" as bo_bff #4169E1

rectangle "Keycloak (Auth)" as kc #DDA0DD

rectangle "Services" as svc #87CEEB {
  [product] as product
  [customer] as customer
  [order] as order
  [media] as media
  [inventory] as inv
  [tax] as tax
  [promotion] as promo
  [sampledata] as sample
}

rectangle "Infrastructure" as infra #E6E6FA {
  database "PostgreSQL" as pg
  [Kafka] as kafka
  database "Redis" as redis
  database "Elasticsearch" as es
}

rectangle "Observability" as obs #D3D3D3 {
  [Loki / Tempo] as lt
  database "Prometheus" as prom_obs
  [Grafana] as grafana
}

rectangle "K3s Cluster (4 nodes)" as k8s #F5F5DC {
  node "master" as m
  node "dev1 / stg1 / prod1" as workers
}

' ----- FLOW -----
admin --> bo_ui
bo_ui --> bo_bff
bo_bff --> kc : OAuth2
bo_bff --> product
bo_bff --> customer
bo_bff --> order
bo_bff --> media
bo_bff --> inv
bo_bff --> tax
bo_bff --> promo
bo_bff --> sample
bo_bff --> redis : session

' ----- SERVICE → INFRA -----
svc --> pg
order --> kafka : events
kafka --> es : CDC

' ----- OBSERVABILITY -----
svc ..> lt
svc ..> prom_obs

note bottom of infra
  3 env: dev / staging / production
  infra identical, different PVC sizes
end note

@enduml
